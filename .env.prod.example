# Copy to .env.prod, fill the required values, then deploy with:
#
#   docker compose --env-file .env.prod -f compose.prod.yml pull
#   docker compose --env-file .env.prod -f compose.prod.yml up -d

# Required: pin the exact published GHCR release.
GEOMARK_VERSION=0.1.2

# Optional: override for forks or private mirrors.
GEOMARK_IMAGE_REGISTRY=ghcr.io/valentinkolb

# Required: public apex domain routed by the external Traefik instance.
DOMAIN=geomark.dev

# Required: existing external Docker network used by Traefik.
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=le

# Required: set a strong value before deployment.
POSTGRES_PASSWORD=change-this-before-deploy

# Required: OpenAddresses bundle ZIP or authenticated Batch collection endpoint.
# For the largest data build, use the Batch Global collection and inject the
# token from fd0/Kubernetes Secret instead of committing it.
OPENADDRESSES_URL=https://batch.openaddresses.io/api/collections/1/data
OPENADDRESSES_TOKEN=

# Optional: public API bearer token. Leave empty for an open API.
API_KEY=

# Optional: production metrics are disabled by default in compose.prod.yml.
METRICS_ENABLED=false
METRICS_TOKEN=

# Optional: tune API behavior.
RATELIMIT_PER_MINUTE=60
RANDOM_CACHE_SECONDS=10
REFERENCE_CACHE_SECONDS=300
REFRESH_INTERVAL_HOURS=6
TRUSTED_PROXY_HOPS=1

# Optional: data refresh cadence and upstream source overrides.
REFRESH_INTERVAL_DAYS=30
GEONAMES_CITIES_URL=https://download.geonames.org/export/dump/allCountries.zip
GEONAMES_POSTAL_URL=https://download.geonames.org/export/zip/allCountries.zip
GEONAMES_COUNTRY_INFO_URL=https://download.geonames.org/export/dump/countryInfo.txt
GEONAMES_ALIASES_URL=https://download.geonames.org/export/dump/alternateNamesV2.zip
