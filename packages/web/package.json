    "@valentinkolb/ssr": "latest",
    "@valentinkolb/stdlib": "latest",
    "hono": "^4.11.7",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4"
  }
}
